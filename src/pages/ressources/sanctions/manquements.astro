---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import manquements from '../../../data/manquements.json';

const themeOrder = ['kyc', 'tm', 'ds', 'ppe', 'gel'] as const;
const themeLabels: Record<string, string> = {
  kyc: 'KYC / Identification',
  tm: 'Transaction Monitoring',
  ds: 'Déclaration de soupçon',
  ppe: 'PPE / Vigilance renforcée',
  gel: 'Gel des avoirs'
};
---

<BaseLayout
  title="Défaillances par type — Sanctions ACPR & AMF 2020–2025 — Early Brief"
  description="400 occurrences de manquements sur 36 décisions ACPR et AMF (2020–2025). Analyse par thème : KYC, TM, DS, PPE, Gel."
  canonicalUrl="https://early-brief.com/ressources/sanctions/manquements/"
>
<div class="page">
    <div class="fiche-content">
    <a href="/ressources/sanctions/" class="fiche-back">Sanctions & jurisprudence</a>

    <div class="fiche-header">
        <div class="fiche-meta">
            <span class="fiche-category" data-cat="sanctions">Sanctions</span>
            <span class="fiche-date">Mis à jour le 21/03/2026</span>
        </div>
        <h1 class="fiche-title">Défaillances par type de manquement</h1>
        <p class="fiche-question">{manquements.meta.total_occurrences} occurrences · {manquements.meta.total_decisions} décisions · {manquements.meta.periode}</p>
    </div>

    <section class="fiche-section">
        <div class="fiche-reponse">
            <p><strong>{manquements.meta.total_occurrences} constats de manquement</strong> extraits de {manquements.meta.total_decisions} décisions ACPR et AMF publiées entre 2020 et 2025. Chaque constat est classé par thème et rattaché à sa décision source.</p>
        </div>
    </section>

    <nav class="fiche-section" style="margin-bottom: 1.5rem;">
        <ul style="list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem;">
            {themeOrder.map(key => (
                <li>
                    <a href={`#${key}`} style="font-family: var(--mono); font-size: 0.7rem; font-weight: 600; color: var(--green); text-transform: uppercase; letter-spacing: 0.08em; padding: 0.3rem 0.6rem; border: 1px solid rgba(44,74,46,0.2); border-radius: 2px; text-decoration: none;">
                        {themeLabels[key]} ({manquements.themes[key].count})
                    </a>
                </li>
            ))}
        </ul>
    </nav>

    {themeOrder.map(key => {
        const theme = manquements.themes[key];
        return (
            <section class="fiche-section" id={key}>
                <h2>{theme.label} — {theme.count} constats</h2>
                <div style="overflow-x: auto;">
                    <table class="comparison-table">
                        <thead>
                            <tr>
                                <th style="width: 8%; text-align: left;">Autorité</th>
                                <th style="width: 14%; text-align: left;">Décision</th>
                                <th style="width: 18%; text-align: left;">Entité</th>
                                <th style="width: 55%; text-align: left;">Constat</th>
                                <th style="width: 5%;">Page</th>
                            </tr>
                        </thead>
                        <tbody>
                            {theme.items.map((item: any) => (
                                <tr>
                                    <td style="text-align: left; font-weight: 400;">{item.autorite}</td>
                                    <td style="text-align: left; font-family: var(--mono); font-size: 0.7rem;">{item.decision}</td>
                                    <td style="text-align: left; font-weight: 500;">{item.entite}</td>
                                    <td style="text-align: left; font-size: 0.75rem; line-height: 1.4;">{item.constat}</td>
                                    <td>{item.page ?? '—'}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </section>
        );
    })}

    <section class="fiche-section fiche-sources">
        <h2>Sources</h2>
        <div class="fiche-source-item">
            <span class="fiche-source-authority">ACPR</span>
            <span class="fiche-source-ref">Recueil des décisions de la Commission des sanctions</span>
            <a href="https://acpr.banque-france.fr/fr/publications-et-statistiques/publications?f%5B0%5D=category_publication%3A116" class="fiche-source-link" target="_blank" rel="noopener noreferrer">Voir la source</a>
        </div>
        <div class="fiche-source-item">
            <span class="fiche-source-authority">AMF</span>
            <span class="fiche-source-ref">Répertoire des décisions de la Commission des sanctions</span>
            <a href="https://www.amf-france.org/fr/sanctions-transactions/sanctions-et-transactions-accueil" class="fiche-source-link" target="_blank" rel="noopener noreferrer">Voir la source</a>
        </div>
    </section>

    <div class="fiche-retour">
      <a href="/ressources/">&larr; Toutes les ressources</a>
    </div>
    </div>
</div>
</BaseLayout>
