---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AuthorBlock from '../../../components/AuthorBlock.astro';
import sanctions from '../../../data/sanctions.json';

const decisions = sanctions.decisions.sort((a, b) => {
  const aDate = a.date.length === 4 ? `${a.date}-12-31` : a.date;
  const bDate = b.date.length === 4 ? `${b.date}-12-31` : b.date;
  return new Date(bDate).getTime() - new Date(aDate).getTime();
});

const formatDate = (d: string) => {
  if (d.length === 4) return d; // year only
  const date = new Date(d);
  return date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
};

const formatAmount = (n: number | null) => {
  if (n === null || n === undefined) return '—';
  if (n === 0) return '—';
  return n.toLocaleString('fr-FR') + ' €';
};

const themeLabels: Record<string, string> = {
  'lcb-ft': 'LCB-FT',
  'tm': 'Transaction monitoring',
  'gel': 'Gel des avoirs',
  'controle-interne': 'Contrôle interne',
  'autres': 'Autres',
};
---

<BaseLayout
  title="Historique des décisions ACPR & AMF 2019–2025 — Early Brief"
  description="39 décisions de sanction ACPR et AMF (2019–2025) : date, entité, montant, thèmes et lien vers la source officielle."
  canonicalUrl="https://early-brief.com/ressources/sanctions/historique/"
>
<div class="page">
    <div class="fiche-content">
    <a href="/ressources/sanctions/" class="fiche-back">Sanctions & jurisprudence</a>

    <div class="fiche-header">
        <div class="fiche-meta">
            <span class="fiche-category" data-cat="sanctions">Sanctions</span>
            <span class="fiche-date">Données mises à jour au 21/03/2026</span>
        </div>
        <h1 class="fiche-title">Décisions ACPR & AMF — 2019–2025</h1>
        <p class="fiche-question">{decisions.length} décisions analysées — sources : recueil ACPR et répertoire AMF.</p>
    </div>

    <section class="fiche-section">
        <table class="comparison-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Autorité</th>
                    <th>Entité</th>
                    <th>Sanction</th>
                    <th>Thèmes</th>
                    <th>Source</th>
                </tr>
            </thead>
            <tbody>
                {decisions.map((d) => (
                    <tr>
                        <td>{formatDate(d.date)}</td>
                        <td><strong>{d.autorite}</strong></td>
                        <td>{d.entite}</td>
                        <td>{d.sanction_pecuniaire ? formatAmount(d.sanction_pecuniaire) : '—'}{d.sanction_disciplinaire ? ` + ${d.sanction_disciplinaire}` : ''}</td>
                        <td>{d.themes.map(t => themeLabels[t] || t).join(', ')}</td>
                        <td><a href={d.source} target="_blank" rel="noopener noreferrer">Source</a></td>
                    </tr>
                ))}
            </tbody>
        </table>
    </section>

    <section class="fiche-section fiche-sources">
        <h2>Sources</h2>
        <div class="fiche-source-item">
            <span class="fiche-source-authority">AMF</span>
            <span class="fiche-source-ref">Sanctions et transactions — Répertoire des décisions</span>
            <a href="https://www.amf-france.org/fr/sanctions-transactions/sanctions-et-transactions-accueil" class="fiche-source-link" target="_blank" rel="noopener noreferrer">Voir la source</a>
        </div>
        <div class="fiche-source-item">
            <span class="fiche-source-authority">ACPR</span>
            <span class="fiche-source-ref">Recueil des sanctions — Décisions de la Commission des sanctions</span>
            <a href="https://acpr.banque-france.fr/fr/reglementation/recueil-des-sanctions" class="fiche-source-link" target="_blank" rel="noopener noreferrer">Voir la source</a>
        </div>
    </section>

    <div class="renvoi-base">
      <span>Retrouvez l'ensemble des textes Sanctions dans la <a href="/reglementations/?bloc=Sanctions">Base réglementaire</a>.</span>
    </div>

    <AuthorBlock lastUpdated="22 mars 2026" />

    <div class="fiche-retour">
      <a href="/ressources/">&larr; Toutes les ressources</a>
    </div>
    </div>
</div>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Décisions ACPR & AMF — 2019–2025",
  "author": { "@type": "Person", "name": "Maria Garcia", "jobTitle": "Consultante conformité" },
  "publisher": { "@type": "Organization", "name": "Early Brief", "legalName": "Early Consulting SAS" },
  "dateModified": "2026-03-22",
  "mainEntityOfPage": "https://early-brief.com/ressources/sanctions/historique/"
})} />
</BaseLayout>
