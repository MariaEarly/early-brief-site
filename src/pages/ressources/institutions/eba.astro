        </div>
        <div class="fiche-source-item">
            <span class="fiche-source-authority">EBA</span>
            <span class="fiche-source-ref">Interactive Single Rulebook</span>
            <a href="https://www.eba.europa.eu/regulation-and-policy/single-rulebook/interactive-single-rulebook" class="fiche-source-link" target="_blank" rel="noopener noreferrer">Voir la source</a>
        </div>
        <div class="fiche-source-item">
