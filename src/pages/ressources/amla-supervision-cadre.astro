    </div>
    <div class="inst-timeline-item">
        <p class="inst-timeline-date">2026</p>
        <p class="inst-timeline-title">Phase de tests méthodologie avec superviseurs nationaux</p>
    </div>
    <div class="inst-timeline-item">
        <p class="inst-timeline-date">31 décembre 2027</p>
        <p class="inst-timeline-title">Application méthodologie d'évaluation des risques (générale UE)</p>
    </div>
    <div class="inst-timeline-item">
        <p class="inst-timeline-date">2027</p>
        <p class="inst-timeline-title">Première sélection entités supervision directe AMLA</p>
    </div>
