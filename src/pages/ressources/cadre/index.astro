---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cadre réglementaire — Early Brief"
  description="Cadre réglementaire européen : LCB-FT, MiCA, DORA, PSD3/PSR. Pages de référence avec périmètre, obligations et sources officielles."
  canonicalUrl="https://early-brief.com/ressources/cadre/"
>
<div class="page">
  <div class="ressources-hero">
    <h1>Cadre réglementaire</h1>
    <p class="ressources-intro">Pages de référence sur les réglementations clés — périmètre, obligations, calendrier et sources officielles.</p>
  </div>
  <div class="ressources-section">
    <div class="ressources-grid">
      <a href="/ressources/cadre/lcb-ft/" class="ressources-card">
        <div class="ressources-card-tag">Référence</div>
        <h2 class="ressources-card-title">LCB-FT</h2>
        <p class="ressources-card-desc">Cadre juridique applicable en France : assujettis, obligations, superviseurs, sources.</p>
        <div class="ressources-card-link">Lire la page →</div>
      </a>
      <a href="/ressources/cadre/mica/" class="ressources-card">
        <div class="ressources-card-tag">Crypto</div>
        <h2 class="ressources-card-title">MiCA</h2>
        <p class="ressources-card-desc">Markets in Crypto-Assets. Périmètre, Titles II–VI, transition PSAN→CASP.</p>
        <div class="ressources-card-link">Lire la page →</div>
      </a>
      <a href="/ressources/cadre/dora/" class="ressources-card">
        <div class="ressources-card-tag">Cyber</div>
        <h2 class="ressources-card-title">DORA</h2>
        <p class="ressources-card-desc">Résilience opérationnelle numérique. Applicable depuis le 17/01/2025.</p>
        <div class="ressources-card-link">Lire la page →</div>
      </a>
      <a href="/ressources/cadre/psd3/" class="ressources-card">
        <div class="ressources-card-tag">Paiements</div>
        <h2 class="ressources-card-title">PSD3/PSR</h2>
        <p class="ressources-card-desc">Nouveau cadre européen des paiements. Anti-fraude, name-check, open banking.</p>
        <div class="ressources-card-link">Lire la page →</div>
      </a>
    </div>
  </div>
  <div class="fiche-retour"><a href="/ressources/">&larr; Toutes les ressources</a></div>
</div>
</BaseLayout>
