                <tr><td><strong>23/04/2024</strong></td><td>Position Parlement (1ère lecture)</td></tr>
                <tr><td><strong>18/06/2025</strong></td><td>Position Conseil (mandat de négociation)</td></tr>
                <tr><td><strong>27/11/2025</strong></td><td>Accord politique provisoire Parlement/Conseil</td></tr>
                <tr><td><strong>Courant 2026</strong></td><td>Publication attendue au JOUE (non publiée au 22/03/2026)</td></tr>
                <tr><td><strong>~21 mois après publication</strong></td><td>Entrée en vigueur, selon le calendrier actuel</td></tr>
            </tbody>
        </table>
    </section>

    <section class="fiche-section">
        <h2>Qui produit les règles ?</h2>
        <h3>Union européenne</h3>
        <ul>
            <li><strong>Commission européenne</strong> — Propose le package et pilote l'agenda réglementaire</li>
            <li><strong>Parlement & Conseil</strong> — Co-législateurs (après trilogues)</li>
            <li><strong>EBA</strong> — Standards techniques, convergence de supervision, prévention de la fraude</li>
            <li><strong>BCE / Eurosystème</strong> — Supervision des infrastructures de paiement</li>
        </ul>
        <h3>France</h3>
        <ul>
            <li><strong>ACPR</strong> — Supervision des EP, EME, PSP</li>
            <li><strong>Banque de France</strong> — Surveillance des moyens de paiement scripturaux</li>
        </ul>
    </section>

