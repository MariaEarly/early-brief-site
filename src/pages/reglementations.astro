---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/reglementations.json';

const textes = data.textes.sort((a, b) => {
  const aDate = a.date_publication ? new Date(a.date_publication).getTime() : 0;
  const bDate = b.date_publication ? new Date(b.date_publication).getTime() : 0;
  return bDate - aDate;
});
const now = new Date();
const enVigueur = textes.filter(t => t.statut === 'En vigueur').length;
const enConsultation = textes.filter(t => t.statut === 'En consultation').length;
const echeancesAVenir = textes.reduce((acc, t) => {
  return acc + t.echeances.filter(e => new Date(e.date) > now).length;
}, 0);

const formatDate = (d: string | null) => {
  if (!d) return '—';
  const date = new Date(d);
  return date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
};

const blocs = [...new Set(textes.map(t => t.bloc))].sort();

const statutColors: Record<string, string> = {
  'En vigueur': '#2C4A2E',
  'En consultation': '#B8860B',
  'Transposition en cours': '#9E3D1B',
  'Adopté — application différée': '#6B6B5A',
  'Projet': '#8A8480',
};
---
<BaseLayout
  title="Base réglementaire — Early Brief"
  description="Référentiel des textes réglementaires en conformité financière : LCB-FT, MiCA, DORA, PSD2, AI Act, sanctions."
  canonicalUrl="https://early-brief.com/reglementations/"
>

<div class="page rb-page">

  <div class="rb-header">
    <h1>Base réglementaire</h1>
    <p class="rb-sub">{textes.length} textes · {enVigueur} en vigueur · {echeancesAVenir} échéances à venir · Mis à jour le {formatDate(data.meta.derniere_mise_a_jour)}</p>
  </div>

  <div class="rb-bar">
    <input type="search" id="rb-search" class="rb-search" placeholder="Rechercher…">
    <div class="rb-chips" id="rb-chips">
      <button class="rb-chip active" data-value="">Tous</button>
      {blocs.map(b => <button class="rb-chip" data-value={b}>{b}</button>)}
    </div>
    <div class="rb-bar-right">
      <select id="rb-sort" class="rb-sort">
        <option value="date-desc">Récents</option>
        <option value="date-asc">Anciens</option>
        <option value="alpha">A → Z</option>
      </select>
      <span class="rb-count" id="rb-count">{textes.length}</span>
    </div>
  </div>

  <div class="rb-list" id="rb-list">
    {textes.map(t => (
      <details class="rb-item" id={t.id}
        data-bloc={t.bloc}
        data-statut={t.statut}
        data-date={t.date_publication || '0000-01-01'}
        data-title={t.titre}
        data-search={`${t.titre} ${t.reference} ${t.institutions_concernees.join(' ')} ${t.bloc} ${t.notes || ''}`.toLowerCase()}>
        <summary class="rb-row">
          <span class="rb-row-bloc">{t.bloc}</span>
          <span class="rb-row-title">{t.titre}</span>
          <span class="rb-row-ref">{t.reference}</span>
          <span class="rb-row-statut" style={`color:${statutColors[t.statut] || '#8A8480'};`}>{t.statut}</span>
          {t.echeances.length > 0 && (
            <span class="rb-row-date">{formatDate(t.echeances[0].date)}</span>
          )}
        </summary>
        <div class="rb-detail">
          {t.notes && <p class="rb-detail-notes">{t.notes}</p>}

          <div class="rb-detail-grid">
            {t.echeances.length > 0 && (
              <div class="rb-detail-col">
                <span class="rb-detail-label">Échéances</span>
                {t.echeances.map(e => (
                  <p class="rb-detail-line"><strong>{formatDate(e.date)}</strong> — {e.description}</p>
                ))}
              </div>
            )}
            {t.textes_lies.length > 0 && (
              <div class="rb-detail-col">
                <span class="rb-detail-label">Textes liés</span>
                {t.textes_lies.map(l => (
                  <p class="rb-detail-line"><a href={l.lien} target="_blank" rel="noopener noreferrer">{l.titre}</a></p>
                ))}
              </div>
            )}
            <div class="rb-detail-col">
              <span class="rb-detail-label">Institutions</span>
              <p class="rb-detail-line">{t.institutions_concernees.join(' · ')}</p>
            </div>
          </div>

          {t.lien_texte_consolide && (
            <a href={t.lien_texte_consolide} target="_blank" rel="noopener noreferrer" class="rb-detail-source">Texte consolidé ↗</a>
          )}
        </div>
      </details>
    ))}
  </div>

  <div class="rb-empty" id="rb-empty" style="display:none;">
    Aucun résultat.
    <button id="rb-reset">Réinitialiser</button>
  </div>

</div>

<script is:inline>
(function() {
  const search = document.getElementById('rb-search');
  const sort = document.getElementById('rb-sort');
  const countEl = document.getElementById('rb-count');
  const list = document.getElementById('rb-list');
  const empty = document.getElementById('rb-empty');
  const resetBtn = document.getElementById('rb-reset');
  const chips = document.querySelectorAll('.rb-chip');
  let items = Array.from(list.querySelectorAll('.rb-item'));
  const total = items.length;
  let activeBloc = '';

  chips.forEach(c => c.addEventListener('click', () => {
    chips.forEach(x => x.classList.remove('active'));
    c.classList.add('active');
    activeBloc = c.dataset.value;
    run();
  }));

  function run() {
    const q = search.value.toLowerCase().trim();
    let shown = 0;
    items.forEach(el => {
      const matchQ = !q || el.dataset.search.includes(q);
      const matchB = !activeBloc || el.dataset.bloc === activeBloc;
      el.style.display = (matchQ && matchB) ? '' : 'none';
      if (matchQ && matchB) shown++;
    });
    countEl.textContent = shown;
    empty.style.display = shown === 0 ? '' : 'none';
  }

  function doSort() {
    const v = sort.value;
    items.sort((a, b) => {
      if (v === 'date-desc') return b.dataset.date.localeCompare(a.dataset.date);
      if (v === 'date-asc') return a.dataset.date.localeCompare(b.dataset.date);
      if (v === 'alpha') return a.dataset.title.localeCompare(b.dataset.title, 'fr');
      return 0;
    });
    items.forEach(el => list.appendChild(el));
  }

  search.addEventListener('input', run);
  sort.addEventListener('change', () => { doSort(); run(); });
  resetBtn.addEventListener('click', () => {
    search.value = '';
    activeBloc = '';
    chips.forEach(c => c.classList.toggle('active', c.dataset.value === ''));
    run();
  });

  run();
})();
</script>

</BaseLayout>
