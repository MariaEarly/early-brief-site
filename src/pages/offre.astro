---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/offre.css';
---

<BaseLayout
  title="Offre de services — Early Brief | Veille réglementaire exploitable"
  description="Veille réglementaire pour CEO, RCCI et équipes conformité de fintechs, PSP et cabinets. Partenariat éditorial, marque blanche ou système de veille internalisé."
  canonicalUrl="https://early-brief.com/offre/"
>
  <div class="page">

    <!-- HERO -->
    <div class="hero">
      <h1>Votre veille réglementaire,<br><em>enfin exploitable</em></h1>
      <p class="hero-desc">Les textes existent. Ce qui manque, c'est quoi faire lundi matin.</p>
    </div>

    <div class="renvoi-base" style="margin:0 0 2rem;">
      <span>← <a href="/veille-reglementaire/">En savoir plus sur la veille réglementaire</a></span>
    </div>

    <!-- TROIS FORMATS -->
    <div class="formats-section">
      <div class="formats-label">Trois formats</div>
      <p class="formats-intro">Chaque format est calibré selon votre agrément et vos obligations réglementaires.</p>

      <!-- FORMAT 01 -->
      <div class="format">
        <div class="format-header">
          <div class="format-num">01</div>
          <div class="format-meta">
            <h2 class="format-title">Partenariat éditorial</h2>
            <div class="format-sub">Votre audience, ma production</div>
          </div>
          <div class="format-price">
            <div class="price-amount">1 500 €</div>
            <div class="price-note">/ mois · 3 mois minimum</div>
          </div>
        </div>
        <div class="format-body">
          <p class="format-desc">Vous diffusez une veille de conformité experte sous votre marque, sans construire la machine éditoriale en interne.</p>
          <ul class="clean">
            <li>2 éditions par mois, clé-en-main</li>
            <li>2 déclinaisons LinkedIn par livraison</li>
            <li>Label "Powered by Early Brief"</li>
          </ul>
        </div>
        <div class="format-diff">→ Votre audience voit que le contenu est produit avec un appui expert</div>
      </div>

      <!-- FORMAT 02 -->
      <div class="format">
        <div class="format-header">
          <div class="format-num">02</div>
          <div class="format-meta">
            <h2 class="format-title">Marque blanche</h2>
            <div class="format-sub">Mon savoir-faire, votre marque</div>
          </div>
          <div class="format-price">
            <div class="price-amount">2 200 €</div>
            <div class="price-note">/ mois · confidentiel</div>
          </div>
        </div>
        <div class="format-body">
          <p class="format-desc">Je produis, vous signez. Le contenu paraît sous votre marque, la source reste confidentielle.</p>
          <ul class="clean">
            <li>Production 100% sous votre identité</li>
            <li>Adaptation complète du ton de marque</li>
            <li>Périmètre thématique adapté à votre agrément et secteur</li>
            <li>2 éditions par mois + déclinaisons LinkedIn</li>
            <li>Exclusivité sectorielle optionnelle</li>
          </ul>
        </div>
        <div class="format-diff">→ La source de production reste invisible pour votre audience</div>
      </div>

      <!-- FORMAT 03 -->
      <div class="format">
        <div class="format-header">
          <div class="format-num">03</div>
          <div class="format-meta">
            <h2 class="format-title">Système de veille</h2>
            <div class="format-sub">La méthode, pas seulement le contenu</div>
          </div>
          <div class="format-price">
            <div class="price-amount accent">4 500 €</div>
            <div class="price-note">setup one-shot · livraison 3 semaines</div>
          </div>
        </div>
        <div class="format-body">
          <p class="format-desc">Je conçois un système de veille que votre équipe peut reprendre, opérer et faire évoluer sans repartir de zéro.</p>
          <ul class="clean">
            <li>Cartographie des sources + critères de tri opérationnels</li>
            <li>Templates de restitution, SOP et playbook complet</li>
            <li>Formation équipe + documentation remise</li>
            <li>Vérification post-déploiement (2 mois) + maintenance optionnelle</li>
          </ul>
          <div class="format-diff">→ Vous récupérez un système, pas seulement un livrable</div>
          <div class="format-price-secondary">
            <div class="price-amount" style="font-size:20px">700 €/mois</div>
            <div class="price-note">suivi &amp; QA — optionnel</div>
          </div>
        </div>
      </div>
    </div>

    <!-- CE QUE VOUS ACHETEZ + CADRE DE COLLABORATION -->
    <div class="bottom">
      <div class="bottom-block">
        <div class="block-title">Ce que vous achetez vraiment</div>
        <ul>
          <li>Réduction du bruit informationnel</li>
          <li>Écriture, angle éditorial et mise en forme inclus</li>
          <li>Détection rapide des signaux utiles</li>
          <li>Lecture orientée risque &amp; impact</li>
          <li>Restitution exploitable par conformité &amp; direction</li>
          <li>Production régulière, lecture fiable</li>
        </ul>
      </div>
      <div class="bottom-block">
        <div class="block-title">Cadre de collaboration</div>
        <ul>
          <li>Périmètre thématique défini contractuellement</li>
          <li>Méthode, sources &amp; architecture restent propriétaires</li>
          <li>Revente à des tiers exclue</li>
          <li>Exclusivité sectorielle = option payante</li>
          <li>Outils IA utilisés sous supervision experte</li>
          <li>Durée minimale 3 mois (formats 01 &amp; 02)</li>
        </ul>
      </div>
    </div>

    <!-- CLOSING CTA -->
    <div class="closing">
      <div>
        <div class="closing-label">Prochaine étape</div>
        <p class="closing-text">Un échange de 30 minutes pour cadrer le périmètre et confirmer le format adapté.</p>
        <a class="cta-btn" href="mailto:contact@early.consulting">Écrire pour échanger</a>
      </div>
      <div class="closing-contact"><a href="mailto:contact@early.consulting" style="color:var(--terra);text-decoration:none">contact@early.consulting</a><br>early-brief.com</div>
    </div>

    <!-- POUR QUI -->
    <div class="pour-qui">
      <div class="pour-qui-label">Pour qui</div>
      <div class="pour-qui-items">
        <span>PSP, EME &amp; établissements de paiement</span>
        <span>CASP &amp; prestataires sur actifs numériques</span>
        <span>Banques &amp; établissements de crédit</span>
        <span>SGP &amp; sociétés de gestion</span>
        <span>Professions non financières assujetties</span>
        <span>Cabinets de conseil &amp; avocats spécialisés</span>
      </div>
    </div>

    <!-- EXEMPLES DE VEILLE -->
    <div class="articles-section">
      <div class="articles-label">Exemples de veille</div>
      <div class="articles-grid">

        <a class="article-card" href="https://mariaiaciancio.substack.com/p/early-brief-14-mars-2026-sanctions" target="_blank" rel="noopener noreferrer">
          <div class="article-meta">14 mars 2026 · Sanctions</div>
          <div class="article-title">Sanctions Russie — FAQ paiements : ce que ça change pour les PSP et EME</div>
          <div class="article-excerpt">La Commission précise quels services de paiement sont visés par l'article 5b(2) — et lesquels ne le sont pas.</div>
          <div class="article-link">Lire sur Substack →</div>
        </a>

        <a class="article-card" href="https://mariaiaciancio.substack.com/p/ia-regulation-financiere-02" target="_blank" rel="noopener noreferrer">
          <div class="article-meta">Mars 2026 · AI Act</div>
          <div class="article-title">IA × Régulation financière #02 — Ce que l'Omnibus numérique change pour les institutions financières</div>
          <div class="article-excerpt">Ce que l'Omnibus numérique change concrètement pour les institutions financières soumises à l'AI Act.</div>
          <div class="article-link">Lire sur Substack →</div>
        </a>

        <a class="article-card" href="https://mariaiaciancio.substack.com/p/early-brief-recap-hebdo-semaine-du-afd" target="_blank" rel="noopener noreferrer">
          <div class="article-meta">Semaine du 9 au 13 mars 2026 · Récap hebdo</div>
          <div class="article-title">GAFI, OFAC, tokenisation — La semaine réglementaire en 30 secondes</div>
          <div class="article-excerpt">GAFI, OFAC, tokenisation — la semaine réglementaire sélectionnée et orientée impact opérationnel.</div>
          <div class="article-link">Lire sur Substack →</div>
        </a>

      </div>
    </div>

    <!-- SEO LLM — texte accessible crawlers -->
    <div class="sr-only">
      Early Brief propose trois formats de veille réglementaire :
      partenariat éditorial à 1500€/mois, marque blanche à 2200€/mois,
      et système de veille internalisé à 4500€.
      Expertise LCB-FT, MiCA, DORA, PSD3, AI Act et sanctions internationales.
    </div>

  </div>

  <!-- Schema.org Service JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Veille réglementaire Early Brief",
    "description": "Veille réglementaire exploitable pour équipes conformité, fintechs, PSP et cabinets — LCB-FT, MiCA, DORA, PSD3, AI Act, Sanctions",
    "provider": {
      "@type": "Person",
      "name": "Maria Garcia",
      "url": "https://early-brief.com",
      "jobTitle": "Responsable conformité & fondatrice Early Brief",
      "knowsAbout": ["LCB-FT", "MiCA", "DORA", "PSD3", "AI Act", "Sanctions", "KYC", "KYB", "lutte contre le blanchiment"]
    },
    "offers": [
      {
        "@type": "Offer",
        "name": "Partenariat éditorial",
        "description": "Newsletter bi-mensuelle clé-en-main sous votre marque",
        "price": "1500",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "1500",
          "priceCurrency": "EUR",
          "unitText": "mois"
        }
      },
      {
        "@type": "Offer",
        "name": "Marque blanche",
        "description": "Production 100% sous votre identité, source confidentielle",
        "price": "2200",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "2200",
          "priceCurrency": "EUR",
          "unitText": "mois"
        }
      },
      {
        "@type": "Offer",
        "name": "Système de veille",
        "description": "Dispositif de veille opérationnel, documenté et réplicable",
        "price": "4500",
        "priceCurrency": "EUR"
      }
    ],
    "areaServed": {
      "@type": "Country",
      "name": "France"
    },
    "inLanguage": "fr"
  }
  </script>
</BaseLayout>
